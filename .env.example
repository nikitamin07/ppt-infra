# === НАСТРОЙКИ САЙТА И ПРОКСИ ===
APP_DOMAIN=localhost
# http на локалке, https на проде
APP_SCHEME=http

# === LARAVEL (BACKEND) ===
# Сгенерировать: php artisan key:generate --show
APP_KEY=
# Кому браузер разрешит читать /api (через запятую).
# На проде — только свой домен; локально добавить next dev: http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:3000

# === ПОДКЛЮЧЕНИЕ К НОВОЙ PostgreSQL ===
PG_USER=db_user
PG_PASSWORD=db_pass
PG_DB=db_name

# === СЕКРЕТНЫЕ КЛЮЧИ И ИНТЕГРАЦИИ ===
# Уведомления о заявках с формы обратного звонка (POST /api/callback) в Telegram.
# TELEGRAM_API — токен бота в формате "bot<token>" (так его ждёт api.telegram.org/{TELEGRAM_API}/sendMessage)
# TELEGRAM_CHATS — chat_id получателей через запятую
TELEGRAM_API=bot_token_here
TELEGRAM_CHATS=chat_id_here